# Supabase — copy to .env.local and fill in from your project's API settings.
# The publishable (anon) key is safe to expose to the browser; RLS enforces access.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Public base URL of the deployed site — used for canonical URLs, sitemap, and OpenGraph.
# In local dev this defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side pepper for hashing reviewer IP addresses before storing them.
# Set to a long random string (e.g. `openssl rand -hex 32`). Without it, IPs are
# still hashed but with an empty pepper — always set a real value in production.
IP_HASH_SECRET=change-me-to-a-long-random-string
